; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="HiShell"
config/description="A desktop and File manager made in Godot"
run/main_scene="uid://bs8jx5somwhse"
config/use_custom_user_dir=true
config/custom_user_dir_name="hishell"
config/features=PackedStringArray("4.6")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/stretch_mode=0
boot_splash/image="uid://bbi2rfqb6edfc"
config/icon="res://assets/higameos_logo.png"

[autoload]

System="*res://lib/system.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=720
window/size/initial_position_type=3
window/size/borderless=true
window/stretch/aspect="expand"
window/stretch/scale=1.25

[editor]

export/convert_text_resources_to_binary=false

[editor_plugins]

enabled=PackedStringArray("res://addons/minimize_html_build/plugin.cfg")

[file_customization]

folder_colors={
"res://Hishell/": "gray",
"res://assets/": "purple",
"res://filesystem/": "gray",
"res://lib/": "teal",
"res://toolkit/": "green"
}

[filesystem]

import/blender/enabled=false

[godots]

version_hint=""

[physics]

2d/physics_engine="Dummy"
3d/physics_engine="Dummy"

[rendering]

environment/defaults/default_clear_color=Color(0, 0, 0, 1)
